# OpenRouter API Key (Primary for hackathon/demo)
# Uses OpenRouter's OpenAI-compatible API endpoint.
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key
OPENROUTER_MODEL=qwen/qwen3-coder:free

# OpenAI API Key (Primary)
# Used when OPENROUTER_API_KEY is not set.
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=codex-mini-latest

GITHUB_PAT=github_pat_token

# Gemini API Key (Fallback)
# Used only when the primary AI provider fails or is unavailable.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Optional public app URL, sent to OpenRouter as attribution metadata.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# GitHub Personal Access Token (Optional)
# Increases rate limits for repository ingestion from 60 to 5000 requests/hour
# Generate a classic token with no scopes, or a fine-grained token with public read-only access.
# GITHUB_PAT=ghp_your_github_personal_access_token

# Firebase (Optional)
# Enables GitHub sign-in and saved scan history.
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
